# Copy this file to .env and fill in your values before running.
#
# .env holds ONLY secrets and deploy/storage locations. All model and pipeline
# settings — model name, backend, fps, temperature, whisper, paths, etc. — live
# in config.yaml. Edit those there, not here.

# ── Secrets ───────────────────────────────────────────────────────────────────
# Discord bot token (required to run the bot).
DISCORD_TOKEN=your_discord_bot_token_here

# HuggingFace token — required only for gated models.
# HUGGING_FACE_HUB_TOKEN=hf_...

# ── Storage locations ─────────────────────────────────────────────────────────
# PRIDE_CACHE_DIR=./.cache

# Docker Compose only: host path where ChromaDB / app data is persisted.
# Defaults to ./pride-data (next to docker-compose.yml).
# DATA_DIR=./pride-db
