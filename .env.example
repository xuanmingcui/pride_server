# Copy this file to .env and fill in your values before running docker compose.

# ── Database location ─────────────────────────────────────────────────────────
# Path on your machine where ChromaDB and app data will be stored.
# Defaults to ./pride-data (next to docker-compose.yml) if not set.
# DATA_DIR=/mnt/storage/pride-db

# ── Required (only for discord bot profile) ───────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Optional model overrides (all have defaults in config.yaml) ───────────────
# PRIDE_MODEL_NAME=Qwen/Qwen3-VL-4B-Instruct-FP8
# PRIDE_BACKEND=vllm
# PRIDE_DEVICE=cuda
# PRIDE_MAX_NEW_TOKENS=2048
# PRIDE_TEMPERATURE=0.8
# PRIDE_WHISPER_MODEL=large-v3
# PRIDE_WHISPER_LANGUAGE=en
# PRIDE_NUM_FRAMES=16

# HuggingFace token — required if using gated models
# HUGGING_FACE_HUB_TOKEN=hf_...
